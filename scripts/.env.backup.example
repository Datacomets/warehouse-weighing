# COMETS GR Backup Configuration
# Copy this file to .env.backup and fill in values

# Supabase project URL
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# Service role key (has full DB access — keep secret!)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Where to store backups (absolute path recommended)
# Default: PROJECT_DIR/backups
BACKUP_DIR="D:/Backups/comets-gr"

# How many days to keep old backups
RETENTION_DAYS=30
